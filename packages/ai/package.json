{
  "name": "@hamhome/ai",
  "version": "1.0.0",
  "private": true,
  "description": "HamHome AI 客户端 SDK",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./providers": {
      "types": "./src/providers.ts",
      "default": "./src/providers.ts"
    },
    "./fallback": {
      "types": "./src/fallback.ts",
      "default": "./src/fallback.ts"
    },
    "./search-rules": {
      "types": "./src/search-rules.ts",
      "default": "./src/search-rules.ts"
    },
    "./search-planner": {
      "types": "./src/search-planner.ts",
      "default": "./src/search-planner.ts"
    },
    "./clients": {
      "types": "./src/clients.ts",
      "default": "./src/clients.ts"
    },
    "./embeddings": {
      "types": "./src/embeddings.ts",
      "default": "./src/embeddings.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hamhome/agent": "workspace:*",
    "@hamhome/types": "workspace:*",
    "@hamhome/utils": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
