{
  "name": "@hamhome/ai",
  "version": "1.0.0",
  "private": true,
  "description": "HamHome AI 客户端 SDK",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./providers": {
      "types": "./src/providers.ts",
      "default": "./src/providers.ts"
    },
    "./fallback": {
      "types": "./src/fallback.ts",
      "default": "./src/fallback.ts"
    },
    "./search-rules": {
      "types": "./src/search-rules.ts",
      "default": "./src/search-rules.ts"
    },
    "./search-planner": {
      "types": "./src/search-planner.ts",
      "default": "./src/search-planner.ts"
    },
    "./clients": {
      "types": "./src/clients.ts",
      "default": "./src/clients.ts"
    },
    "./embeddings": {
      "types": "./src/embeddings.ts",
      "default": "./src/embeddings.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.78.0",
    "@hamhome/types": "workspace:*",
    "@hamhome/utils": "workspace:*",
    "@langchain/anthropic": "1.3.22",
    "@langchain/core": "1.1.31",
    "@langchain/openai": "1.2.12"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
