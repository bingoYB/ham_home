{
  "name": "hamhome",
  "version": "1.0.0",
  "private": true,
  "description": "HamHome 浏览器插件",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:all": "pnpm build && pnpm build:firefox && pnpm build:edge",
    "analyze": "ANALYZE=true wxt build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "zip:all": "pnpm zip && pnpm zip:firefox && pnpm zip:edge",
    "clean": "rm -rf .wxt .output dist",
    "submit:init": "wxt submit init",
    "submit:all": "node scripts/submit.js"
  },
  "dependencies": {
    "@hamhome/agent": "workspace:*",
    "@hamhome/ui": "workspace:*",
    "@hamhome/utils": "workspace:*",
    "@langchain/openai": "1.2.12",
    "@mozilla/readability": "^0.5.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@webext-core/proxy-service": "^2.0.0",
    "defuddle": "^0.14.0",
    "fflate": "^0.8.2",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^7.0.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.0",
    "p-limit": "^7.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "webdav": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/chrome": "^0.0.260",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@wxt-dev/module-react": "^1.1.5",
    "postcss-rem-to-pixel": "^4.1.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "wxt": "^0.20.13"
  }
}
